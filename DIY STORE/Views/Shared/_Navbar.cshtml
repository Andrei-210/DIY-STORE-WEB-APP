@using DIY_STORE.Models
@using DIY_STORE.Data
@using DIY_STORE.Services
@inject ICategoryService CategoryService
@inject Microsoft.AspNetCore.Identity.UserManager<ApplicationUser> UserManager

@{
    var navCategories = (await CategoryService.GetAllCategoriesAsync()).ToList();
    string? profilePicUrl = null;
    string? displayName = null;

    if (User.Identity?.IsAuthenticated == true)
    {
        var currentUser = await UserManager.GetUserAsync(User);
        if (currentUser != null)
        {
            displayName = currentUser.UserName;
            if (!string.IsNullOrEmpty(currentUser.ProfilePicturePath))
                profilePicUrl = $"/images/{currentUser.ProfilePicturePath}";
        }
    }
}

@if (User.IsInRole("Admin"))
{
    <a asp-controller="Admin" asp-action="Index" class="nav-link d-none">Admin</a>
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/navbar.css">

<style>
    .navbar-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #f59e0b;
        vertical-align: middle;
    }

    .navbar-avatar-placeholder {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #f59e0b;
        color: #1a1a1a;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 700;
        border: 2px solid #fcd34d;
        vertical-align: middle;
    }

    /* Cart badge */
    #cart-count {
        font-size: 0.62rem;
        padding: 2px 5px;
        min-width: 18px;
        line-height: 1.4;
    }
</style>

<nav class="navbar navbar-dark bg-dark flex-column py-0">
    <!-- Randul 1: Brand + Search + Iconuri -->
    <div class="container d-flex justify-content-between align-items-center py-2">
        <!-- Brand -->
        <a class="navbar-brand mb-0" asp-controller="Home" asp-action="Index">DIY STORE</a>

        <!-- Search bar -->
        <form class="flex-grow-1 mx-3 d-flex" role="search" asp-controller="Products" asp-action="Search" method="get">
            <input class="form-control me-2" type="search" name="q" placeholder="Product search...">
            <button class="btn btn-outline-light" type="submit">Search</button>
        </form>

        <!-- Iconuri: Favorite, Cos, Cont -->
        <div class="d-flex align-items-center gap-1">
            <a class="btn btn-outline-light" asp-controller="Account" asp-action="Profile" asp-route-section="favorites">❤ Favorites</a>

            <!-- Cart button with item count badge -->
            <a class="btn btn-outline-light position-relative" asp-controller="Cart" asp-action="Index">
                🛒 Cart
                <span id="cart-count"
                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                      style="display:none;">0</span>
            </a>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="dropdown">
                    <button class="btn btn-outline-light dropdown-toggle d-flex align-items-center gap-2"
                            type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        @if (profilePicUrl != null)
                        {
                            <img src="@profilePicUrl" alt="@displayName" class="navbar-avatar" />
                        }
                        else
                        {
                            <span class="navbar-avatar-placeholder">
                                @(displayName?.Substring(0, 1).ToUpper() ?? "U")
                            </span>
                        }
                        <span class="d-none d-md-inline">@displayName</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        @if (profilePicUrl != null)
                        {
                            <li class="px-3 pt-2 pb-1 text-center" style="background:#2d2d2d;border-radius:6px 6px 0 0;">
                                <img src="@profilePicUrl" alt="@displayName"
                                     style="width:60px;height:60px;border-radius:50%;object-fit:cover;border:2px solid #f59e0b;">
                                <div class="small mt-1 fw-semibold" style="color:#fff;">@displayName</div>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                        }
                        else
                        {
                            <li class="px-3 pt-2 pb-1 text-center" style="background:#2d2d2d;border-radius:6px 6px 0 0;">
                                <div class="small mt-1 fw-semibold" style="color:#fff;">@displayName</div>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                        }
                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile" asp-route-section="account">👤 Profile</a></li>
                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile" asp-route-section="orders">📦 My orders</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">🚪 Log out</button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <div class="dropdown">
                    <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Account
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Login">Login</a></li>
                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Register">Sign up</a></li>
                    </ul>
                </div>
            }

            @if (User.IsInRole("Admin"))
            {
                <a class="btn btn-outline-warning ms-1" asp-controller="Admin" asp-action="Index">⚙ Admin</a>
            }
        </div>
    </div>

    <!-- Randul 2: Meniu principal -->
    <div class="container d-flex py-1">
        <div class="dropdown">
            <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                Product Categories
            </button>
            <ul class="dropdown-menu">
                @if (!navCategories.Any())
                {
                    <li><span class="dropdown-item text-muted">No categories yet</span></li>
                }
                @foreach (var cat in navCategories)
                {
                    <li>
                        <a class="dropdown-item" asp-controller="Categories" asp-action="Index" asp-route-cat="@cat.Slug">
                            @cat.Name
                        </a>
                    </li>
                }
            </ul>
        </div>

        <a asp-controller="Support" asp-action="Index" class="btn btn-outline-light ms-0">Customer support</a>
        <a asp-controller="Shops" asp-action="Index" class="btn btn-outline-light ms-0">Shops</a>
        <a asp-controller="Products" asp-action="Promotions" class="btn btn-outline-light ms-0">Promotions</a>
    </div>
</nav>

<script>
    // Update cart badge on every page load
    (function () {
        async function refreshCartBadge() {
            try {
                const r = await fetch('/Cart/Count');
                if (!r.ok) return;
                const d = await r.json();
                const badge = document.getElementById('cart-count');
                if (!badge) return;
                if (d.count > 0) {
                    badge.textContent = d.count;
                    badge.style.display = '';
                } else {
                    badge.style.display = 'none';
                }
            } catch {}
        }
        refreshCartBadge();
    })();
</script>
