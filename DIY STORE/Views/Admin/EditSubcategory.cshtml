@model DIY_STORE.Models.Subcategory
@{
    ViewData["Title"] = "Edit Subcategory";
    var categories = ViewBag.Categories as IEnumerable<DIY_STORE.Models.Category>
                     ?? Enumerable.Empty<DIY_STORE.Models.Category>();
}

<div class="container py-5">
    <h2 class="mb-4">✏️ Edit Subcategory: @Model.Name</h2>
    <div class="card shadow-sm p-4" style="max-width:500px;">
        <form asp-action="EditSubcategory" asp-route-slug="@Model.Slug" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Parent Category</label>
                <select asp-for="CategoryId" class="form-select" required>
                    <option value="">– Select category –</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">@cat.Name</option>
                    }
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Subcategory Name</label>
                <input asp-for="Name" class="form-control" required>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Image (optional)</label>
                @if (!string.IsNullOrEmpty(Model.Image))
                {
                    <div class="mb-2 d-flex align-items-center gap-2">
                        <img src="~/images/@Model.Image" alt="@Model.Name"
                             style="max-height:60px;max-width:80px;object-fit:contain;border:1px solid #dee2e6;border-radius:4px;padding:2px;">
                        <small class="text-muted">Current: @Model.Image</small>
                    </div>
                    <input type="hidden" asp-for="Image" />
                }
                <input type="file" name="ImageFile" class="form-control" accept="image/*">
                <div class="form-text">Upload a new image (leave empty to keep existing).</div>
            </div>
            <button type="submit" class="btn btn-warning w-100">Save Changes</button>
        </form>
    </div>
    <a asp-action="Categories" class="btn btn-outline-secondary mt-3">← Back</a>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
