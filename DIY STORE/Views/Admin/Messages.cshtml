@model IEnumerable<DIY_STORE.Models.ContactMessage>
@{ ViewData["Title"] = "Support Messages"; }

<div class="container py-5">
    <h2 class="mb-4">✉️ Support Messages</h2>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    <table class="table table-hover">
        <thead class="table-dark">
            <tr><th>Date</th><th>Name</th><th>Email</th><th>Subject</th><th>Read</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var msg in Model)
            {
                <tr class="@(msg.IsRead ? "" : "fw-bold")">
                    <td>@msg.Date.ToString("dd MMM yyyy")</td>
                    <td>@msg.Name</td>
                    <td>@msg.Email</td>
                    <td>@msg.Subject</td>
                    <td>@(msg.IsRead ? "✅" : "🔴")</td>
                    <td class="d-flex gap-1">
                        <a asp-action="MessageDetails" asp-route-id="@msg.Id" class="btn btn-sm btn-outline-dark">View</a>
                        <form asp-action="DeleteMessage" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@msg.Id" />
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <a asp-action="Index" class="btn btn-outline-secondary mt-2">← Back to Dashboard</a>
</div>
