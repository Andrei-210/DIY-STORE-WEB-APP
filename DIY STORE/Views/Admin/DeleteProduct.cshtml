@model DIY_STORE.Models.Product
@{ ViewData["Title"] = "Delete Product"; }

<div class="container py-5" style="max-width:600px;">
    <div class="card shadow-sm border-danger p-4">
        <h3 class="text-danger">🗑️ Delete Product</h3>
        <p>Are you sure you want to delete <strong>@Model.Name</strong>?</p>
        <dl class="row">
            <dt class="col-4">Price</dt><dd class="col-8">@Model.Price.ToString("0.00") RON</dd>
            <dt class="col-4">Stock</dt><dd class="col-8">@Model.Stock</dd>
        </dl>
        <form asp-action="DeleteProduct" method="post" class="d-flex gap-2 mt-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a asp-action="Products" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
