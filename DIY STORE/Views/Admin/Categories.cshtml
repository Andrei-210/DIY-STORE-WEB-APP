@model IEnumerable<DIY_STORE.Models.Category>
@{ ViewData["Title"] = "Admin – Categories"; }

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🗂️ Manage Categories</h2>
        <div class="d-flex gap-2">
            <a asp-action="CreateSubcategory" class="btn btn-outline-warning">+ Add Subcategory</a>
            <a asp-action="CreateCategory" class="btn btn-warning">+ Add Category</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @foreach (var cat in Model)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center bg-dark text-white">
                <div>
                    <strong>@cat.Name</strong>
                    <code class="ms-2 text-warning">@cat.Slug</code>
                    <span class="badge bg-secondary ms-2">@cat.Subcategories.Count subcategories</span>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="EditCategory" asp-route-slug="@cat.Slug" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="DeleteCategory" asp-route-slug="@cat.Slug" class="btn btn-sm btn-danger">Delete</a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (cat.Subcategories.Any())
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Subcategory Name</th>
                                <th>Image</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sub in cat.Subcategories)
                            {
                                <tr>
                                    <td>@sub.Name</td>
                                    <td><code>@(string.IsNullOrEmpty(sub.Image) ? "–" : sub.Image)</code></td>
                                    <td>
                                        <a asp-action="EditSubcategory" asp-route-slug="@sub.Slug" class="btn btn-sm btn-outline-warning">Edit</a>
                                        <a asp-action="DeleteSubcategory" asp-route-slug="@sub.Slug" class="btn btn-sm btn-outline-danger">Delete</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">No subcategories yet.
                        <a asp-action="CreateSubcategory">Add one</a>
                    </p>
                }
            </div>
        </div>
    }

    <a asp-action="Index" class="btn btn-outline-secondary mt-2">← Back to Dashboard</a>
</div>
