@model DIY_STORE.Models.Subcategory
@{ ViewData["Title"] = "Delete Subcategory"; }

<div class="container py-5">
    <h2 class="mb-4">🗑️ Delete Subcategory</h2>
    <div class="card shadow-sm p-4" style="max-width:500px;">
        <p>Are you sure you want to delete subcategory <strong>@Model.Name</strong>?</p>
        <p class="text-muted">This will also remove all products linked to this subcategory.</p>
        <form asp-action="DeleteSubcategory" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger w-100">Yes, Delete</button>
        </form>
    </div>
    <a asp-action="Categories" class="btn btn-outline-secondary mt-3">← Back</a>
</div>
