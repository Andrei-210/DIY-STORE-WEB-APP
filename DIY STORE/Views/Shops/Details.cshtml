@model DIY_STORE.Models.Shop
@{
    ViewData["Title"] = "Shop Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/shops.css">
}

<div class="container py-5">
    <h2 class="mb-4">Shop Details</h2>

    <div class="card shadow-sm" style="max-width: 600px;">
        <img src="~/images/shop_placeholder.webp" class="card-img-top" alt="Shop @Model.City">
        <div class="card-body">
            <h4 class="card-title">@Model.City</h4>
            <hr>
            <p><strong>Address:</strong> @Model.Address</p>
            <p><strong>Hours:</strong> @Model.Hours</p>
            <p><strong>Phone:</strong> @Model.Phone</p>
            <p><strong>Email:</strong> <a href="mailto:@Model.Email">@Model.Email</a></p>
        </div>
        <div class="card-footer d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
        </div>
    </div>
</div>
