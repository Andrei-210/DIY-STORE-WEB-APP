@model DIY_STORE.Models.Shop
@{
    ViewData["Title"] = "Edit Shop";
}

@section Styles {
    <link rel="stylesheet" href="~/css/shops.css">
}

<div class="container py-5">
    <h2 class="mb-4">Edit Shop</h2>
    <div class="card shadow-sm p-4" style="max-width: 600px;">
        <form asp-action="Edit" asp-route-slug="@Model.Slug" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id">
            <div class="mb-3">
                <label asp-for="City" class="form-label">City</label>
                <input asp-for="City" class="form-control" required>
                <span asp-validation-for="City" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-label">Address</label>
                <input asp-for="Address" class="form-control" required>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Hours" class="form-label">Working Hours</label>
                <input asp-for="Hours" class="form-control" required>
                <span asp-validation-for="Hours" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Phone" class="form-label">Phone</label>
                <input asp-for="Phone" class="form-control" required>
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" type="email" required>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Shop Image</label>
                @if (!string.IsNullOrEmpty(Model.Image))
                {
                    <div class="mb-2 d-flex align-items-center gap-2">
                        <img src="~/images/@Model.Image" alt="@Model.City"
                             style="max-height:80px;max-width:120px;object-fit:contain;border:1px solid #dee2e6;border-radius:6px;padding:4px;">
                        <small class="text-muted">Current: @Model.Image</small>
                    </div>
                    <input type="hidden" asp-for="Image" />
                }
                <input type="file" name="ImageFile" class="form-control" accept="image/*">
                <div class="form-text">Upload a new image (leave empty to keep existing).</div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">Save Changes</button>
                <a asp-action="Details" asp-route-slug="@Model.Slug" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
