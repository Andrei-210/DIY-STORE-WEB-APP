@using DIY_STORE.Models
@{
    ViewData["Title"] = "Home";
    var popularCategories = ViewBag.PopularCategories as List<Category> ?? new List<Category>();
    var featuredProducts = ViewBag.FeaturedProducts as List<Product> ?? new List<Product>();
    var favoriteIds = ViewBag.FavoriteIds as List<int> ?? new List<int>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/style.css">
}

<!-- HERO SECTION -->
<section class="hero-section text-center">
    <div class="container">
        <h1 class="hero-title">Everything you need for your DIY projects</h1>
        <p class="hero-subtitle">Tools, materials, and accessories at the best prices</p>
        <a asp-controller="Products" asp-action="Promotions" class="btn btn-warning btn-lg hero-btn">
            Promotions
        </a>
    </div>
</section>

<!-- Toast container -->
<div id="toast-container" style="position:fixed;bottom:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px;"></div>

<!-- CATEGORII POPULARE -->
<section class="categories-section container my-5">
    <h2 class="text-center mb-4">Popular Categories</h2>
    <div class="row g-4 justify-content-center">
        @if (!popularCategories.Any())
        {
            <div class="col-12 text-center text-muted">No categories found. Add some from the Admin panel.</div>
        }
        @foreach (var cat in popularCategories)
        {
            var catImg = string.IsNullOrEmpty(cat.Image) ? "placeholder.webp" : cat.Image;
            <div class="col-md-4">
                <div class="card shadow-sm h-100 category-card">
                    <img src="~/images/@catImg" class="card-img-top category-img" alt="@cat.Name"
                         style="height:180px;object-fit:cover;">
                    <div class="card-body text-center">
                        <h5>@cat.Name</h5>
                        <a asp-controller="Categories" asp-action="Index" asp-route-cat="@cat.Slug"
                           class="btn btn-outline-dark mt-2 explore-btn">Explore</a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<!-- PRODUSE RECOMANDATE -->
<section class="products-section bg-light py-5">
    <div class="container">
        <h2 class="text-center mb-4">Featured Products</h2>
        <div class="row g-4">
            @if (!featuredProducts.Any())
            {
                <div class="col-12 text-center text-muted">No products yet. Add some from the Admin panel.</div>
            }
            @foreach (var product in featuredProducts)
            {
                var img = product.Images.FirstOrDefault()?.ImagePath ?? "placeholder.webp";
                img = img.Replace("images/", "");
                bool isFav = favoriteIds.Contains(product.Id);
                <div class="col-md-3">
                    <div class="card shadow-sm h-100 product-card text-center position-relative">
                        @if (product.IsOnSale)
                        {
                            <span class="badge bg-danger position-absolute top-0 end-0 m-2" style="z-index:2">SALE</span>
                        }
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <button class="fav-btn position-absolute top-0 start-0 m-1 @(isFav ? "active" : "")"
                                    style="z-index:2;background:none;border:none;font-size:1.3rem;line-height:1;padding:4px 6px;color:@(isFav ? "#dc3545" : "#aaa");"
                                    data-product-id="@product.Id"
                                    title="Toggle favorite"
                                    onclick="toggleFavorite(this, @product.Id)">❤</button>
                        }
                        <img src="~/images/@img" class="card-img-top p-2" style="max-height:180px;object-fit:contain;" alt="@product.Name">
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title">@product.Name</h6>
                            @if (product.OldPrice.HasValue)
                            {
                                <p class="text-muted text-decoration-line-through mb-0">@product.OldPrice.Value.ToString("0.00") RON</p>
                            }
                            <p class="fw-bold text-warning mb-2">@product.Price.ToString("0.00") RON</p>
                            <div class="d-flex gap-1 mt-auto">
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id"
                                   class="btn btn-outline-secondary btn-sm flex-fill rounded-pill">View</a>
                                <button class="btn btn-warning btn-sm flex-fill rounded-pill add-to-cart-btn"
                                        data-product-id="@product.Id"
                                        data-product-name="@product.Name"
                                        data-product-price="@product.Price"
                                        data-product-image="images/@img">
                                    Add to Cart
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/cart.js"></script>
    @using Microsoft.AspNetCore.Antiforgery
    @inject IAntiforgery Antiforgery
    @{ var tokens = Antiforgery.GetAndStoreTokens(Context); }
    <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" id="global-csrf-token">

    <script>
        function getToken() {
            return document.getElementById('global-csrf-token')?.value || '';
        }

        function showToast(msg, type = "success") {
            const c = document.getElementById("toast-container");
            const t = document.createElement("div");
            t.className = `alert alert-${type} shadow mb-0`;
            t.style.cssText = "min-width:280px;animation:fadeIn .3s;";
            t.textContent = msg;
            c.appendChild(t);
            setTimeout(() => { t.style.opacity = 0; t.style.transition = "opacity .4s"; }, 2800);
            setTimeout(() => t.remove(), 3200);
        }

        async function toggleFavorite(btn, productId) {
            const tok = getToken();
            if (!tok) { window.location = '/Account/Login'; return; }
            try {
                const r = await fetch('/Products/ToggleFavorite', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
                    body: `productId=${productId}&__RequestVerificationToken=${encodeURIComponent(tok)}`
                });
                const d = await r.json();
                if (d.success) {
                    btn.classList.toggle('active', d.isFavorite);
                    btn.style.color = d.isFavorite ? '#dc3545' : '#aaa';
                    showToast(d.isFavorite ? '❤ Added to favorites!' : '💔 Removed from favorites!', d.isFavorite ? 'success' : 'warning');
                }
            } catch { showToast('Error. Please try again.', 'danger'); }
        }
    </script>
    <style>@@keyframes fadeIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }</style>
}
