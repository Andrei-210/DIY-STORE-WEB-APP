@{
    ViewData["Title"] = "About Us";
}

@section Styles {
    <link rel="stylesheet" href="~/css/about.css">
}

<section class="about-section">
    <div class="container">
        <div class="text-center mb-5">
            <h1>About DIY Store</h1>
            <p>DIY Store is your trusted partner for high-quality tools and home improvement products. We are dedicated to providing our customers with the best selection of professional and consumer-grade tools to empower creativity and efficiency in every project.</p>
        </div>

        <div class="row align-items-center mb-5">
            <div class="col-md-6">
                <img src="~/images/about_tools.jpg" class="img-fluid rounded" alt="Tools and workshop">
            </div>
            <div class="col-md-6">
                <h2>Our Mission</h2>
                <p>Our mission is to support DIY enthusiasts, professionals, and hobbyists alike by offering reliable, high-quality tools at competitive prices. We aim to make every project easier, safer, and more enjoyable.</p>
            </div>
        </div>

        <div class="row align-items-center mb-5">
            <div class="col-md-6 order-md-2">
                <img src="~/images/about_team.jpg" class="img-fluid rounded" alt="Team working">
            </div>
            <div class="col-md-6 order-md-1">
                <h2>Our History</h2>
                <div class="history-timeline">
                    <div class="history-event">
                        <h5>2005 - Foundation</h5>
                        <p>DIY Store was founded with the vision of making quality tools accessible to every home and workshop.</p>
                    </div>
                    <div class="history-event">
                        <h5>2010 - Expansion</h5>
                        <p>Expanded our product range and opened additional retail stores across the country, reaching more customers than ever before.</p>
                    </div>
                    <div class="history-event">
                        <h5>2018 - E-commerce Launch</h5>
                        <p>Launched our online store to provide convenient shopping from anywhere, with fast delivery and secure payments.</p>
                    </div>
                    <div class="history-event">
                        <h5>2023 - Innovation & Growth</h5>
                        <p>Introduced new exclusive brands, smart tools, and enhanced customer service to continue being the market leader.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center">
            <h2>Why Choose Us?</h2>
            <p>At DIY Store, quality, reliability, and customer satisfaction are our top priorities. We carefully select every product and brand to ensure that our customers receive the best value and performance.</p>
        </div>
    </div>
</section>
