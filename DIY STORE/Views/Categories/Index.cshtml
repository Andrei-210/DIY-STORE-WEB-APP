@{
    ViewData["Title"] = ViewBag.Title as string ?? "Category";
    var subcategories = ViewBag.Subcategories as IEnumerable<DIY_STORE.Models.Subcategory>
                        ?? Enumerable.Empty<DIY_STORE.Models.Subcategory>();
}

@section Styles {
    <style>
        .card-img-top { max-height: 220px; object-fit: contain; }
        .cat-card:hover { transform: translateY(-4px); box-shadow: 0 6px 20px rgba(0,0,0,.15); transition: .2s; }
    </style>
}

<section class="pb-5">
    <div class="container mt-5">
        <h2>@ViewBag.Title</h2>

        @if (!subcategories.Any())
        {
            <div class="alert alert-info mt-3">No subcategories found for this category.</div>
        }

        <div class="row g-4 mt-2">
            @foreach (var sub in subcategories)
            {
                <div class="col-md-4">
                    <div class="card shadow-sm mb-3 h-100 d-flex flex-column cat-card">
                        <img src="~/images/@sub.Image.Replace("images/","")"
                             class="card-img-top p-2"
                             alt="@sub.Name">
                        <div class="card-body d-flex flex-column text-center">
                            <h5 class="mb-3 mt-auto">@sub.Name</h5>
                            <a asp-controller="Products"
                               asp-action="Index"
                               asp-route-cat="@ViewBag.Cat"
                               asp-route-sub="@sub.Name"
                               class="btn btn-warning">
                                View products
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
